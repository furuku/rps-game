generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HighScore {
  id        Int      @id @default(1)
  score     Int      @default(0)
  updatedAt DateTime @updatedAt
}
